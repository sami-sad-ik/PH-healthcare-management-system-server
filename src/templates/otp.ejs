<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your OTP Code</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: #f0f4ff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      max-width: 580px;
      margin: 0 auto;
      padding: 48px 20px;
    }

    /* Brand */
    .brand {
      text-align: center;
      margin-bottom: 28px;
    }
    .brand-logo {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .brand-icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-name {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 800;
      color: #1e1b4b;
      letter-spacing: -0.02em;
    }

    /* Card */
    .card {
      background: #ffffff;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 4px 6px rgba(99,102,241,0.05), 0 20px 60px rgba(99,102,241,0.1);
    }

    /* Hero strip */
    .card-hero {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
      padding: 44px 48px 40px;
      position: relative;
      overflow: hidden;
    }
    .card-hero::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 220px; height: 220px;
      background: rgba(255,255,255,0.07);
      border-radius: 50%;
    }
    .card-hero::after {
      content: '';
      position: absolute;
      bottom: -60px; left: -20px;
      width: 160px; height: 160px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 100px;
      padding: 5px 12px;
      font-size: 11px;
      font-weight: 600;
      color: #fff;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .hero-dot {
      width: 6px; height: 6px;
      background: #a5f3fc;
      border-radius: 50%;
    }
    .hero-title {
      font-family: 'Syne', sans-serif;
      font-size: 30px;
      font-weight: 800;
      color: #fff;
      line-height: 1.25;
      margin-bottom: 8px;
      position: relative;
      z-index: 1;
    }
    .hero-title span {
      color: #fde68a;
    }
    .hero-sub {
      font-size: 14px;
      color: rgba(255,255,255,0.72);
      font-weight: 400;
      line-height: 1.6;
      position: relative;
      z-index: 1;
    }

    /* Body */
    .card-body {
      padding: 40px 48px;
    }

    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #a5b4fc;
      margin-bottom: 12px;
    }

    /* OTP display */
    .otp-wrapper {
      background: #f8f7ff;
      border: 2px dashed #c7d2fe;
      border-radius: 16px;
      padding: 28px 32px;
      text-align: center;
      margin-bottom: 20px;
      position: relative;
    }
    .otp-digits {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .otp-full {
      font-family: 'Syne', sans-serif;
      font-size: 48px;
      font-weight: 800;
      letter-spacing: 0.18em;
      color: #4f46e5;
      line-height: 1;
    }
    .otp-hint {
      margin-top: 10px;
      font-size: 12px;
      color: #a5b4fc;
      font-weight: 500;
    }

    /* Timer */
    .timer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      border-radius: 12px;
      padding: 14px 20px;
      margin-bottom: 32px;
    }
    .timer-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .timer-icon-wrap {
      width: 32px; height: 32px;
      background: #ffedd5;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .timer-text {
      font-size: 13px;
      font-weight: 600;
      color: #c2410c;
    }
    .timer-sub {
      font-size: 11px;
      color: #fb923c;
      font-weight: 400;
    }
    .timer-badge {
      font-size: 12px;
      font-weight: 700;
      color: #ea580c;
      background: #ffedd5;
      border-radius: 8px;
      padding: 4px 10px;
    }

    /* Divider */
    .divider {
      height: 1px;
      background: linear-gradient(to right, transparent, #e0e7ff, transparent);
      margin-bottom: 28px;
    }

    /* Info box */
    .info-box {
      display: flex;
      gap: 14px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 12px;
      padding: 16px 20px;
      margin-bottom: 12px;
    }
    .info-icon {
      flex-shrink: 0;
      width: 20px; height: 20px;
      margin-top: 1px;
    }
    .info-text {
      font-size: 13px;
      color: #166534;
      line-height: 1.65;
      font-weight: 400;
    }
    .info-text strong { font-weight: 600; }

    .warn-box {
      display: flex;
      gap: 14px;
      background: #fefce8;
      border: 1px solid #fde68a;
      border-radius: 12px;
      padding: 16px 20px;
    }
    .warn-text {
      font-size: 13px;
      color: #854d0e;
      line-height: 1.65;
    }
    .warn-text strong { font-weight: 600; }

    /* Footer */
    .card-footer {
      background: #fafafa;
      border-top: 1px solid #f0f0f0;
      padding: 24px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .footer-text {
      font-size: 12px;
      color: #9ca3af;
      line-height: 1.6;
    }
    .footer-links {
      display: flex;
      gap: 16px;
    }
    .footer-links a {
      font-size: 12px;
      color: #a5b4fc;
      text-decoration: none;
      font-weight: 500;
    }

    /* Outer */
    .outer-note {
      text-align: center;
      margin-top: 24px;
      font-size: 11px;
      color: #9ca3af;
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Brand -->
    <div class="brand">
      <div class="brand-logo">
        <div class="brand-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#fff" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M2 17l10 5 10-5" stroke="#fff" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M2 12l10 5 10-5" stroke="#fff" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="brand-name">YourApp</span>
      </div>
    </div>

    <!-- Card -->
    <div class="card">

      <!-- Hero -->
      <div class="card-hero">
        <div class="hero-tag">
          <span class="hero-dot"></span>
          Verification Required
        </div>
        <div class="hero-title">Hey, <span><%= name %></span> 👋</div>
        <p class="hero-sub">Here's your one-time passcode to verify your identity.<br/>Please use it before it expires.</p>
      </div>

      <!-- Body -->
      <div class="card-body">

        <div class="section-label">Your one-time password</div>

        <div class="otp-wrapper">
          <div class="otp-full"><%= otp %></div>
          <div class="otp-hint">Enter this code to continue</div>
        </div>

        <!-- Timer -->
        <div class="timer-row">
          <div class="timer-left">
            <div class="timer-icon-wrap">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="#f97316" stroke-width="1.8"/>
                <path d="M12 7v5l3 3" stroke="#f97316" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <div class="timer-text">Code expires soon</div>
              <div class="timer-sub">Do not share with anyone</div>
            </div>
          </div>
          <div class="timer-badge">2 min</div>
        </div>

        <div class="divider"></div>

        <!-- Info boxes -->
        <div class="info-box">
          <svg class="info-icon" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="9" stroke="#22c55e" stroke-width="1.6"/>
            <path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="#22c55e" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p class="info-text">
            <strong>You're all set!</strong> This code was generated just for you. Enter it on the verification page to complete your login securely.
          </p>
        </div>

        <div style="height:10px"></div>

        <div class="warn-box">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;margin-top:1px">
            <path d="M10 2L2 17h16L10 2z" stroke="#eab308" stroke-width="1.6" stroke-linejoin="round"/>
            <path d="M10 8v4" stroke="#eab308" stroke-width="1.6" stroke-linecap="round"/>
            <circle cx="10" cy="14.5" r="0.75" fill="#eab308"/>
          </svg>
          <p class="warn-text">
            <strong>Didn't request this?</strong> Someone may be trying to access your account. Ignore this email — your account remains safe and untouched.
          </p>
        </div>

      </div>

      <!-- Footer -->
      <div class="card-footer">
        <p class="footer-text">
          © 2025 YourApp · Automated security email<br/>
          123 Main Street, City, Country
        </p>
        <div class="footer-links">
          <a href="#">Help</a>
          <a href="#">Privacy</a>
          <a href="#">Unsubscribe</a>
        </div>
      </div>

    </div>

    <p class="outer-note">This is an automated message. Please do not reply to this email.</p>

  </div>
</body>
</html>
